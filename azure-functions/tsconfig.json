{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "outDir": ".",
    "rootDir": "src",
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__/**/*", "src/__mocks__/**/*", "**/*.test.ts", "**/*.spec.ts"]
}
